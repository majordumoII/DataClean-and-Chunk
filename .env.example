# GCP Project
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json

# Document AI
DOCAI_LOCATION=us
DOCAI_PROCESSOR_ID=your-processor-id

# GCS Buckets
INPUT_BUCKET=corporate-raw-docs
OUTPUT_BUCKET=corporate-processed-docs

# Chunking
CHUNK_SIZE=1024
CHUNK_OVERLAP=200

# Embedding (Vertex AI)
EMBEDDING_MODEL=text-embedding-005
EMBEDDING_DIMENSIONS=768
EMBEDDING_LOCATION=us-east1

# Cloud SQL pgvector
# Local dev (via Cloud SQL Auth Proxy on localhost):
#   Format: postgresql://user:password@host:5432/dbname
PG_CONNECTION_STRING=postgresql://pipeline:changeme@localhost:5432/docpipeline
VECTOR_TABLE=document_chunks

# Cloud SQL pgvector — Cloud Function / Composer deployments
# When DB_INSTANCE_CONNECTION_NAME is set, VectorStore connects via the
# Cloud SQL Python Connector (IAM auth) instead of PG_CONNECTION_STRING.
# Required for environments with no stable IP to allowlist (Composer,
# Cloud Run) and no Cloud SQL Auth Proxy sidecar.
DB_INSTANCE_CONNECTION_NAME=your-project:region:instance-name
DB_NAME=docpipeline
DB_USER=pipeline
DB_PASSWORD=changeme
