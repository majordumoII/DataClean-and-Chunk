# GCP Project
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json

# Document AI
DOCAI_LOCATION=us
DOCAI_PROCESSOR_ID=your-processor-id

# GCS Buckets
INPUT_BUCKET=corporate-raw-docs
OUTPUT_BUCKET=corporate-processed-docs

# Chunking
CHUNK_SIZE=1024
CHUNK_OVERLAP=200

# Embedding (Vertex AI)
EMBEDDING_MODEL=text-embedding-005
EMBEDDING_DIMENSIONS=768
EMBEDDING_LOCATION=us-east1

# Cloud SQL pgvector
# Format: postgresql://user:password@host:5432/dbname
# If using Cloud SQL Auth Proxy, host is localhost:5432
PG_CONNECTION_STRING=postgresql://pipeline:changeme@localhost:5432/docpipeline
VECTOR_TABLE=document_chunks
